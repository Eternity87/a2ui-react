{
  "a2ui": [
    {
      "beginRendering": {
        "surfaceId": "main",
        "catalogId": "basic"
      }
    },
    {
      "surfaceUpdate": {
        "surfaceId": "main",
        "components": [
          {
            "id": "root",
            "component": "Dashboard",
            "props": {
              "children": ["drillInfo", "stat1", "stat2", "stat3", "stat4", "cardBar", "cardLine", "cardPie", "cardArea", "cardCombo", "cardScatter", "cardRadar", "cardRadial"],
              "columns": 12, "gap": 16
            }
          },
          { "id": "drillInfo", "component": "Text", "props": { "_w": 12, "text": "下钻结果: ${/drillMonth} — 销售额 ${/drillSales}", "size": "base", "color": "text-blue-500" } },
          { "id": "stat1", "component": "StatCard", "props": { "_w": 3, "label": "总销售额", "value": { "path": "/kpiSales" }, "prefix": "¥", "suffix": "万", "trend": { "path": "/kpiSalesTrend" }, "trendLabel": "同比", "sparklineData": { "path": "/kpiSalesSpark" } } },
          { "id": "stat2", "component": "StatCard", "props": { "_w": 3, "label": "总订单量", "value": { "path": "/kpiOrders" }, "suffix": "单", "trend": { "path": "/kpiOrdersTrend" }, "trendLabel": "同比", "sparklineData": { "path": "/kpiOrdersSpark" }, "color": "#52c41a" } },
          { "id": "stat3", "component": "StatCard", "props": { "_w": 3, "label": "客单价", "value": { "path": "/kpiAvgPrice" }, "prefix": "¥", "suffix": "万", "trend": { "path": "/kpiAvgPriceTrend" }, "trendLabel": "环比", "sparklineData": { "path": "/kpiAvgPriceSpark" }, "color": "#faad14" } },
          { "id": "stat4", "component": "StatCard", "props": { "_w": 3, "label": "利润率", "value": { "path": "/kpiProfitRate" }, "suffix": "%", "trend": { "path": "/kpiProfitRateTrend" }, "trendLabel": "同比", "sparklineData": { "path": "/kpiProfitRateSpark" }, "color": "#722ed1" } },
          { "id": "cardBar",    "component": "Card", "props": { "_w": 6, "title": "月度销售额（柱状图）",      "children": ["barChart"] } },
          { "id": "cardLine",   "component": "Card", "props": { "_w": 6, "title": "营收趋势（折线图）",        "children": ["lineChart"] } },
          { "id": "cardPie",    "component": "Card", "props": { "_w": 6, "title": "市场份额（饼图）",          "children": ["pieChart"] } },
          { "id": "cardArea",   "component": "Card", "props": { "_w": 6, "title": "订单量趋势（面积图）",      "children": ["areaChart"] } },
          { "id": "cardCombo",  "component": "Card", "props": { "_w": 6, "title": "销售额与利润率（组合图）",  "children": ["comboChart"] } },
          { "id": "cardScatter","component": "Card", "props": { "_w": 6, "title": "广告投入 vs 销售额（散点图）","children": ["scatterChart"] } },
          { "id": "cardRadar",  "component": "Card", "props": { "_w": 6, "title": "产品综合评分（雷达图）",    "children": ["radarChart"] } },
          { "id": "cardRadial", "component": "Card", "props": { "_w": 6, "title": "季度目标完成率（径向图）",  "children": ["radialChart"] } },
          {
            "id": "barChart",
            "component": "BarChart",
            "props": {
              "data": { "path": "/barData" },
              "xField": "month", "yField": "sales",
              "title": "2026 上半年销售额", "height": 280, "color": "#1890ff",
              "showDataLabel": true,
              "referenceValue": 500, "referenceLabel": "目标 500",
              "targetValue": 500,
              "reactionId": "onBarClick"
            }
          },
          {
            "id": "lineChart",
            "component": "LineChart",
            "props": {
              "data": { "path": "/lineData" },
              "xField": "month", "yField": "revenue",
              "title": "2026 上半年营收趋势", "height": 280, "color": "#52c41a",
              "showDataLabel": true,
              "referenceValue": 100, "referenceLabel": "目标 100 万",
              "targetValue": 100,
              "reactionId": "onLineClick"
            }
          },
          {
            "id": "pieChart",
            "component": "PieChart",
            "props": {
              "data": { "path": "/pieData" },
              "labelField": "name", "valueField": "value",
              "title": "各品类市场占比", "height": 280,
              "colors": "#1890ff,#52c41a,#faad14,#f5222d,#722ed1",
              "labelFormat": "namePercent",
              "labelPosition": "outside", "labelOffset": 10,
              "targetValue": 20,
              "reactionId": "onPieClick"
            }
          },
          {
            "id": "areaChart",
            "component": "AreaChart",
            "props": {
              "data": { "path": "/areaData" },
              "xField": "month", "yField": "orders",
              "title": "2026 上半年订单量", "height": 280, "color": "#faad14",
              "showDataLabel": true,
              "referenceValue": 400, "referenceLabel": "目标 400",
              "targetValue": 400,
              "reactionId": "onAreaClick"
            }
          },
          {
            "id": "comboChart",
            "component": "ComposedChart",
            "props": {
              "data": { "path": "/comboData" },
              "xField": "month", "yField": "sales", "yField2": "profitRate",
              "title": "2026 上半年销售额与利润率", "height": 280,
              "color": "#1890ff", "color2": "#f5222d",
              "showDataLabel": true,
              "referenceValue": 500, "referenceLabel": "目标 500",
              "reactionId": "onComboClick"
            }
          },
          {
            "id": "scatterChart",
            "component": "ScatterChart",
            "props": {
              "data": { "path": "/scatterFiltered" },
              "xField": "ad", "yField": "sales",
              "title": "广告投入(万) vs 销售额(万)", "height": 280, "color": "#722ed1",
              "showDataLabel": true,
              "referenceValue": 500, "referenceLabel": "目标 500"
            }
          },
          {
            "id": "radarChart",
            "component": "RadarChart",
            "props": {
              "data": { "path": "/radarData" },
              "nameKey": "metric", "dataKey": "score",
              "title": "产品综合评分", "height": 280, "color": "#faad14", "fillOpacity": 0.25,
              "reactionId": "onRadarClick"
            }
          },
          {
            "id": "radialChart",
            "component": "RadialBarChart",
            "props": {
              "data": { "path": "/radialData" },
              "nameKey": "quarter", "valueKey": "rate",
              "title": "各季度目标完成率(%)", "height": 280,
              "colors": "#1890ff,#52c41a,#faad14,#f5222d",
              "reactionId": "onRadialClick"
            }
          }
        ]
      }
    },
    { "updateDataModel": { "surfaceId": "main", "path": "/_event", "value": {} } },
    { "updateDataModel": { "surfaceId": "main", "path": "/drillMonth", "value": "" } },
    { "updateDataModel": { "surfaceId": "main", "path": "/drillSales", "value": 0 } },
    { "updateDataModel": { "surfaceId": "main", "path": "/clickMonth", "value": "" } },
    { "updateDataModel": { "surfaceId": "main", "path": "/clickSales", "value": 0 } },
    { "updateDataModel": { "surfaceId": "main", "path": "/salesLastYear", "value": 490 } }
  ],
  "logic": {
    "reactions": [
      {
        "id": "initLoad",
        "when": { "field": "/_", "event": "init" },
        "then": [
          { "type": "apiRequest", "url": "/api/dashboard/kpi", "outputTo": "/rawKpi" },
          { "type": "apiRequest", "url": "/api/dashboard/monthly-stats", "outputTo": "/rawMonthly" },
          { "type": "apiRequest", "url": "/api/dashboard/category-share", "outputTo": "/rawCategory" },
          { "type": "apiRequest", "url": "/api/dashboard/ad-vs-sales", "outputTo": "/rawScatter" },
          { "type": "apiRequest", "url": "/api/dashboard/product-scores", "outputTo": "/rawScores" },
          { "type": "apiRequest", "url": "/api/dashboard/quarterly-targets", "outputTo": "/rawTargets" },
          {
            "type": "setValues",
            "map": {
              "/kpiSales":         { "pipe": [{ "get": "/rawKpi.totalSales" }] },
              "/kpiSalesTrend":    { "pipe": [{ "get": "/rawKpi.salesTrend" }] },
              "/kpiSalesSpark":    { "pipe": [{ "get": "/rawKpi.salesSpark" }] },
              "/kpiOrders":        { "pipe": [{ "get": "/rawKpi.totalOrders" }] },
              "/kpiOrdersTrend":   { "pipe": [{ "get": "/rawKpi.ordersTrend" }] },
              "/kpiOrdersSpark":   { "pipe": [{ "get": "/rawKpi.ordersSpark" }] },
              "/kpiAvgPrice":      { "pipe": [{ "get": "/rawKpi.avgPrice" }] },
              "/kpiAvgPriceTrend": { "pipe": [{ "get": "/rawKpi.avgPriceTrend" }] },
              "/kpiAvgPriceSpark": { "pipe": [{ "get": "/rawKpi.avgPriceSpark" }] },
              "/kpiProfitRate":      { "pipe": [{ "get": "/rawKpi.profitRate" }] },
              "/kpiProfitRateTrend": { "pipe": [{ "get": "/rawKpi.profitRateTrend" }] },
              "/kpiProfitRateSpark": { "pipe": [{ "get": "/rawKpi.profitRateSpark" }] },
              "/barData":   { "pipe": [{ "get": "/rawMonthly.list" }] },
              "/lineData":  { "pipe": [{ "get": "/rawMonthly.list" }] },
              "/areaData":  { "pipe": [{ "get": "/rawMonthly.list" }] },
              "/comboData": { "pipe": [{ "get": "/rawMonthly.list" }] },
              "/pieData":   { "pipe": [{ "get": "/rawCategory.list" }] },
              "/radarData": { "pipe": [{ "get": "/rawScores.list" }] },
              "/radialData": { "pipe": [{ "get": "/rawTargets.list" }] },
              "/scatterAll": { "pipe": [{ "get": "/rawScatter.list" }] },
              "/scatterFiltered": { "pipe": [{ "get": "/rawScatter.list" }] },
              "/salesYoY": {
                "pipe": [{ "yoy": { "current": "/kpiSales", "previous": "/salesLastYear" } }]
              }
            }
          }
        ]
      },
      {
        "id": "onUnload",
        "when": { "field": "/_", "event": "unload" },
        "then": [
          { "type": "toast", "message": "看板已关闭，推送连接已断开", "variant": "info" }
        ]
      },
      {
        "id": "onBarClick",
        "when": { "field": "barChart", "event": "click" },
        "then": [
          {
            "type": "setValues",
            "map": {
              "/clickMonth": { "pipe": [{ "get": "/_event.month" }] },
              "/clickSales": { "pipe": [{ "get": "/_event.sales" }] }
            }
          },
          {
            "type": "condition",
            "branches": [
              {
                "if": "$clickMonth === $drillMonth",
                "then": [
                  {
                    "type": "setValues",
                    "map": {
                      "/drillMonth": "",
                      "/drillSales": 0,
                      "/scatterFiltered": { "pipe": [{ "get": "/scatterAll" }] }
                    }
                  },
                  { "type": "toast", "message": "已取消联动，散点图恢复全量", "variant": "info" }
                ]
              },
              {
                "then": [
                  {
                    "type": "setValues",
                    "map": {
                      "/drillMonth": { "pipe": [{ "get": "/_event.month" }] },
                      "/drillSales": { "pipe": [{ "get": "/_event.sales" }] },
                      "/scatterFiltered": {
                        "pipe": [
                          { "get": "/scatterAll" },
                          { "filter": "$.sales >= _event.sales" }
                        ]
                      }
                    }
                  },
                  { "type": "toast", "message": "联动: 散点图已过滤，点击同月取消", "variant": "success" }
                ]
              }
            ]
          }
        ]
      },
      {
        "id": "onAreaClick",
        "when": { "field": "areaChart", "event": "click" },
        "then": [
          {
            "type": "setValues",
            "map": {
              "/areaTotal": {
                "pipe": [
                  { "get": "/areaData" },
                  { "compute": "$value.reduce((s,i) => s + i.orders, 0)" }
                ]
              }
            }
          },
          { "type": "toast", "message": "2026上半年订单量: 共 ${/areaData.length} 个月，合计 ${/areaTotal} 单", "variant": "info" }
        ]
      },
      {
        "id": "onComboClick",
        "when": { "field": "comboChart", "event": "click" },
        "then": [
          {
            "type": "setValues",
            "map": {
              "/drillMonth": { "pipe": [{ "get": "/_event.month" }] },
              "/drillSales": { "pipe": [{ "get": "/_event.sales" }] }
            }
          },
          { "type": "toast", "message": "选中 ${/drillMonth}: 销售额 ${/drillSales} 万，利润率 ${/_event.profitRate}%", "variant": "info" }
        ]
      },
      {
        "id": "onRadarClick",
        "when": { "field": "radarChart", "event": "click" },
        "then": [
          { "type": "toast", "message": "产品综合评分雷达图已点击", "variant": "info" }
        ]
      },
      {
        "id": "onRadialClick",
        "when": { "field": "radialChart", "event": "click" },
        "then": [
          {
            "type": "setValues",
            "map": {
              "/drillMonth": { "pipe": [{ "get": "/_event.quarter" }] },
              "/drillSales": { "pipe": [{ "get": "/_event.rate" }] }
            }
          },
          { "type": "toast", "message": "${/_event.quarter} 目标完成率: ${/_event.rate}%", "variant": "success" }
        ]
      },
      {
        "id": "onLineClick",
        "when": { "field": "lineChart", "event": "click" },
        "then": [
          {
            "type": "setValues",
            "map": {
              "/lineAvg": {
                "pipe": [
                  { "get": "/lineData" },
                  { "compute": "Math.round($value.reduce((s,i) => s + i.revenue, 0) / $value.length)" }
                ]
              }
            }
          },
          { "type": "toast", "message": "2026上半年营收: 共 ${/lineData.length} 个月，月均 ${/lineAvg} 万", "variant": "info" }
        ]
      },
      {
        "id": "onPieClick",
        "when": { "field": "pieChart", "event": "click" },
        "then": [
          { "type": "toast", "message": "${/_event.name}: 占比 ${/_event.value}%", "variant": "info" }
        ]
      }
    ]
  }
}
