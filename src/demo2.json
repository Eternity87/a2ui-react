{
  "a2ui": [
    {
      "beginRendering": {
        "surfaceId": "main",
        "catalogId": "basic"
      }
    },
    {
      "surfaceUpdate": {
        "surfaceId": "main",
        "components": [
          {
            "id": "root",
            "component": "Card",
            "props": {
              "title": "订单列表",
              "children": ["searchRow", "orderTable"]
            }
          },
          {
            "id": "searchRow",
            "component": "Row",
            "props": {
              "children": ["searchField", "searchBtn"],
              "gap": 8
            }
          },
          {
            "id": "searchField",
            "component": "TextField",
            "props": {
              "label": "搜索",
              "value": { "path": "/searchKeyword" },
              "placeholder": "订单号 / 产品名"
            }
          },
          {
            "id": "searchBtn",
            "component": "Button",
            "props": {
              "label": "搜索",
              "variant": "primary",
              "reactionId": "searchOrders"
            }
          },
          {
            "id": "orderTable",
            "component": "DataTable",
            "props": {
              "columns": [
                { "key": "orderId", "label": "订单号" },
                { "key": "productName", "label": "产品" },
                { "key": "quantity", "label": "数量" },
                { "key": "unitPrice", "label": "单价" },
                { "key": "totalPrice", "label": "总价" },
                { "key": "status", "label": "状态" },
                { "key": "createdAt", "label": "创建时间" }
              ],
              "value": { "path": "/orders" },
              "emptyText": "暂无订单数据"
            }
          }
        ]
      }
    },
    { "updateDataModel": { "surfaceId": "main", "path": "/searchKeyword", "value": "" } },
    { "updateDataModel": { "surfaceId": "main", "path": "/orders", "value": [] } }
  ],
  "logic": {
    "reactions": [
      {
        "id": "loadOrders",
        "when": { "field": "/_", "event": "init" },
        "then": [
          {
            "type": "apiRequest",
            "url": "/api/orders",
            "method": "GET",
            "outputTo": "/rawOrders"
          },
          {
            "type": "setValues",
            "map": {
              "/orders": {
                "pipe": [
                  { "get": "/rawOrders.list" }
                ]
              }
            }
          }
        ]
      },
      {
        "id": "searchOrders",
        "when": { "field": "searchBtn", "event": "click" },
        "then": [
          {
            "type": "apiRequest",
            "url": "/api/orders",
            "method": "GET",
            "params": {
              "keyword": "/searchKeyword"
            },
            "outputTo": "/rawOrders"
          },
          {
            "type": "setValues",
            "map": {
              "/orders": {
                "pipe": [
                  { "get": "/rawOrders.list" }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}