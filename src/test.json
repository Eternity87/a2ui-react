{
  "a2ui": [
    { "beginRendering": { "surfaceId": "main", "catalogId": "basic" } },
    { "surfaceUpdate": { "surfaceId": "main", "components": [
      { "id": "searchCard", "component": "Card", "props": { "children": ["searchRow"], "title": "订单搜索" } },
      { "id": "searchRow", "component": "Row", "props": { "children": ["keywordField", "searchBtn"], "gap": 8 } },
      { "id": "keywordField", "component": "TextField", "props": { "label": "关键词", "value": "/keyword", "placeholder": "输入订单号或产品名" } },
      { "id": "searchBtn", "component": "Button", "props": { "label": "搜索", "variant": "primary", "reactionId": "searchOrders" } },
      { "id": "orderTable", "component": "DataTable", "props": { "columns": [
        { "key": "orderId", "label": "订单号" },
        { "key": "product", "label": "产品" },
        { "key": "quantity", "label": "数量" },
        { "key": "unitPrice", "label": "单价" },
        { "key": "totalPrice", "label": "总价" },
        { "key": "status", "label": "状态" },
        { "key": "createdAt", "label": "创建时间" }
      ], "value": "/orders", "emptyText": "暂无订单数据" } },
      { "id": "orderCard", "component": "Card", "props": { "children": ["orderTable"], "title": "订单列表" } }
    ] } },
    { "updateDataModel": { "surfaceId": "main", "path": "/keyword", "value": "" } },
    { "updateDataModel": { "surfaceId": "main", "path": "/orders", "value": [] } }
  ],
  "logic": {
    "reactions": [
      {
        "id": "loadOrders",
        "when": { "field": "/keyword", "event": "init" },
        "then": [
          { "type": "apiRequest", "url": "/api/orders", "method": "GET", "params": { "keyword": "/keyword" }, "outputTo": "/rawOrders" },
          { "type": "setValues", "map": { "/orders": { "pipe": [{ "get": "/rawOrders.list" }] } } }
        ]
      },
      {
        "id": "searchOrders",
        "when": { "field": "searchBtn", "event": "click" },
        "then": [
          { "type": "apiRequest", "url": "/api/orders", "method": "GET", "params": { "keyword": "/keyword" }, "outputTo": "/rawOrders" },
          { "type": "setValues", "map": { "/orders": { "pipe": [{ "get": "/rawOrders.list" }] } } }
        ]
      }
    ]
  }
}