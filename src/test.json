{
    "pages": {
        "page_form": {
            "a2ui": [
                {
                    "beginRendering": {
                        "surfaceId": "main",
                        "catalogId": "basic"
                    }
                },
                {
                    "surfaceUpdate": {
                        "surfaceId": "main",
                        "components": [
                            {
                                "id": "root",
                                "component": "Row",
                                "props": {
                                    "children": [
                                        "formCol"
                                    ]
                                }
                            },
                            {
                                "id": "formCol",
                                "component": "Row",
                                "props": {
                                    "children": [
                                        "categorySelect",
                                        "productSelect",
                                        "unitPriceField",
                                        "quantityField",
                                        "totalPriceText",
                                        "submitBtn"
                                    ],
                                    "gap": 16
                                }
                            },
                            {
                                "id": "categorySelect",
                                "component": "Select",
                                "props": {
                                    "label": "产品大类",
                                    "value": {
                                        "path": "/productCategory"
                                    },
                                    "options": [
                                        {
                                            "label": "电子产品",
                                            "value": "electronics"
                                        },
                                        {
                                            "label": "家具",
                                            "value": "furniture"
                                        },
                                        {
                                            "label": "服装",
                                            "value": "clothing"
                                        }
                                    ],
                                    "width": "300px"
                                }
                            },
                            {
                                "id": "productSelect",
                                "component": "Select",
                                "props": {
                                    "label": "产品子类",
                                    "value": {
                                        "path": "/productId"
                                    },
                                    "options": {
                                        "path": "/productOptions"
                                    },
                                    "width": "300px"
                                }
                            },
                            {
                                "id": "unitPriceField",
                                "component": "TextField",
                                "props": {
                                    "label": "单价",
                                    "value": {
                                        "path": "/unitPrice"
                                    },
                                    "type": "number",
                                    "disabled": true,
                                    "width": "150px"
                                }
                            },
                            {
                                "id": "quantityField",
                                "component": "TextField",
                                "props": {
                                    "label": "数量",
                                    "value": {
                                        "path": "/quantity"
                                    },
                                    "type": "number",
                                    "width": "150px"
                                }
                            },
                            {
                                "id": "totalPriceText",
                                "component": "Text",
                                "props": {
                                    "text": "总价: ${/totalPrice} 元",
                                    "size": "lg",
                                    "bold": true
                                }
                            },
                            {
                                "id": "submitBtn",
                                "component": "Button",
                                "props": {
                                    "label": "提交订单",
                                    "variant": "primary",
                                    "reactionId": "onSubmit"
                                }
                            }
                        ]
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/productCategory",
                        "value": ""
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/productId",
                        "value": ""
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/productOptions",
                        "value": []
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/unitPrice",
                        "value": 0
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/quantity",
                        "value": 1
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/totalPrice",
                        "value": 0
                    }
                }
            ],
            "logic": {
                "reactions": [
                    {
                        "id": "onCategoryChange",
                        "when": {
                            "field": "/productCategory",
                            "event": "change"
                        },
                        "then": [
                            {
                                "type": "cascade",
                                "target": "/productId"
                            },
                            {
                                "type": "apiRequest",
                                "url": "/api/products",
                                "params": {
                                    "category": "/productCategory"
                                },
                                "outputTo": "/rawProducts"
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/productOptions": {
                                        "pipe": [
                                            {
                                                "get": "/rawProducts.list"
                                            },
                                            {
                                                "map": "({ label: $.name, value: $.id })"
                                            }
                                        ]
                                    }
                                }
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/unitPrice": 0,
                                    "/totalPrice": 0
                                }
                            }
                        ]
                    },
                    {
                        "id": "onProductChange",
                        "when": {
                            "field": "/productId",
                            "event": "change"
                        },
                        "then": [
                            {
                                "type": "apiRequest",
                                "url": "/api/product-detail",
                                "params": {
                                    "id": "/productId"
                                },
                                "outputTo": "/rawProductDetail"
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/unitPrice": {
                                        "pipe": [
                                            {
                                                "get": "/rawProductDetail.price"
                                            }
                                        ]
                                    }
                                }
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/totalPrice": {
                                        "pipe": [
                                            {
                                                "get": "/unitPrice"
                                            },
                                            {
                                                "compute": "$value * quantity"
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "id": "onQuantityChange",
                        "when": {
                            "field": "/quantity",
                            "event": "change"
                        },
                        "then": [
                            {
                                "type": "setValues",
                                "map": {
                                    "/totalPrice": {
                                        "pipe": [
                                            {
                                                "get": "/unitPrice"
                                            },
                                            {
                                                "compute": "$value * quantity"
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "id": "onSubmit",
                        "when": {
                            "field": "submitBtn",
                            "event": "click"
                        },
                        "then": [
                            {
                                "type": "validate",
                                "rules": [
                                    {
                                        "field": "/productCategory",
                                        "required": true,
                                        "message": "请选择产品大类"
                                    },
                                    {
                                        "field": "/productId",
                                        "required": true,
                                        "message": "请选择产品"
                                    },
                                    {
                                        "field": "/quantity",
                                        "required": true,
                                        "message": "请输入数量"
                                    }
                                ],
                                "errorTarget": "/errors"
                            },
                            {
                                "type": "apiRequest",
                                "url": "/api/orders",
                                "method": "POST",
                                "params": {
                                    "productId": "/productId",
                                    "quantity": "/quantity",
                                    "unitPrice": "/unitPrice"
                                },
                                "outputTo": "/rawOrder"
                            },
                            {
                                "type": "toast",
                                "message": "订单创建成功",
                                "variant": "success"
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/productCategory": "",
                                    "/productId": "",
                                    "/productOptions": [],
                                    "/unitPrice": 0,
                                    "/quantity": 1,
                                    "/totalPrice": 0
                                }
                            }
                        ]
                    }
                ]
            }
        }
    }
}