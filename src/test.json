{
    "pages": {
        "page_list": {
            "a2ui": [
                {
                    "beginRendering": {
                        "surfaceId": "main",
                        "catalogId": "basic"
                    }
                },
                {
                    "surfaceUpdate": {
                        "surfaceId": "main",
                        "components": [
                            {
                                "id": "card",
                                "component": "Card",
                                "title": "订单列表",
                                "children": [
                                    "searchRow",
                                    "orderTable"
                                ]
                            },
                            {
                                "id": "searchRow",
                                "component": "Row",
                                "gap": 8,
                                "children": [
                                    "keywordInput",
                                    "searchBtn"
                                ]
                            },
                            {
                                "id": "keywordInput",
                                "component": "TextField",
                                "label": "关键词",
                                "value": {
                                    "path": "/keyword"
                                },
                                "placeholder": "订单号/产品名"
                            },
                            {
                                "id": "searchBtn",
                                "component": "Button",
                                "label": "搜索",
                                "reactionId": "searchOrders"
                            },
                            {
                                "id": "orderTable",
                                "component": "DataTable",
                                "value": {
                                    "path": "/orders"
                                },
                                "columns": [
                                    {
                                        "key": "orderId",
                                        "label": "订单号"
                                    },
                                    {
                                        "key": "product",
                                        "label": "产品"
                                    },
                                    {
                                        "key": "quantity",
                                        "label": "数量"
                                    },
                                    {
                                        "key": "unitPrice",
                                        "label": "单价"
                                    },
                                    {
                                        "key": "totalPrice",
                                        "label": "总价"
                                    },
                                    {
                                        "key": "status",
                                        "label": "状态"
                                    },
                                    {
                                        "key": "createdAt",
                                        "label": "创建时间"
                                    }
                                ]
                            }
                        ]
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/keyword",
                        "value": ""
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/rawOrders",
                        "value": {}
                    }
                },
                {
                    "updateDataModel": {
                        "surfaceId": "main",
                        "path": "/orders",
                        "value": []
                    }
                }
            ],
            "logic": {
                "reactions": [
                    {
                        "id": "initLoad",
                        "when": {
                            "field": "/keyword",
                            "event": "init"
                        },
                        "then": [
                            {
                                "type": "apiRequest",
                                "url": "/api/orders",
                                "outputTo": "/rawOrders"
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/orders": {
                                        "pipe": [
                                            {
                                                "get": "/rawOrders.list"
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "id": "searchOrders",
                        "when": {
                            "field": "searchBtn",
                            "event": "click"
                        },
                        "then": [
                            {
                                "type": "apiRequest",
                                "url": "/api/orders",
                                "params": {
                                    "keyword": "/keyword"
                                },
                                "outputTo": "/rawOrders"
                            },
                            {
                                "type": "setValues",
                                "map": {
                                    "/orders": {
                                        "pipe": [
                                            {
                                                "get": "/rawOrders.list"
                                            }
                                        ]
                                    }
                                }
                            }
                        ]
                    }
                ]
            }
        }
    }
}